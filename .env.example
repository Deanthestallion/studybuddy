# ─────────────────────────────────────────────────────────────
# Study Buddy — environment configuration (12-factor)
# Copy to .env and adjust. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# Runtime
NODE_ENV=development
API_PORT=4000
# Comma-separated list of allowed browser origins (CORS)
CORS_ORIGINS=http://localhost:5173

# Postgres (matches docker-compose defaults)
DATABASE_URL=postgresql://studybuddy:studybuddy@localhost:5432/studybuddy?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# Auth — generate strong secrets in production (openssl rand -hex 32)
JWT_ACCESS_SECRET=dev-access-secret-change-me-please-32+chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-me-please-32+chars
ACCESS_TOKEN_TTL=900            # seconds (15 min)
REFRESH_TOKEN_TTL=1209600       # seconds (14 days)
PASSWORD_RESET_TTL=3600         # seconds (1 hour)

# Rate limiting (sliding window)
RATE_LIMIT_WINDOW=60            # seconds
RATE_LIMIT_MAX=120              # requests per window per identity

# Frontend (apps/web) — Vite reads VITE_* vars
VITE_API_URL=http://localhost:4000/api/v1
